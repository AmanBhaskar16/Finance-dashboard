generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  income
  expense
}

model Transaction {
  id        String          @id @default(cuid())
  amount    Float
  category  String
  type      TransactionType
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
}
