  {
    "version": 2,
    "builds": [
        {
            "src": "/src/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": ["dist/**", "prisma/**"]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/src/index.js"
        }
    ]
}